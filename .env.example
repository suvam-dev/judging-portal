# Judging Portal - Environment Variables Template
# ================================================
# Copy this file to .env.local and fill in your actual values
# IMPORTANT: .env.local is in .gitignore - never commit real secrets!

# =========================
# DATABASE CONFIGURATION
# =========================

# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
# For local MongoDB: mongodb://localhost:27017/judging_portal
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/judging_portal

# =========================
# AUTHENTICATION
# =========================

# JWT Secret Key for signing tokens
# MUST be at least 32 characters for security
# Generate with: openssl rand -base64 32
# Keep this VERY SECRET and UNIQUE for each environment
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long-keep-it-safe

# JWT Token Expiration (optional, default: 1h)
# Format: 24h, 7d, 1h, 30m, etc.
# JWT_EXPIRES_IN=24h

# =========================
# APPLICATION ENVIRONMENT
# =========================

# Node environment
# Options: development, production, test
NODE_ENV=development

# Application URL (used for redirects, emails, etc.)
# For local development: http://localhost:3000
# For production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================
# OPTIONAL: EMAIL CONFIGURATION
# =========================

# Email service for sending notifications (optional)
# Examples: gmail, sendgrid, smtp
# EMAIL_SERVICE=sendgrid
# EMAIL_API_KEY=your-api-key
# EMAIL_FROM=noreply@judging-portal.com

# =========================
# OPTIONAL: AWS/FILE STORAGE
# =========================

# AWS S3 for file uploads (optional)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=us-east-1

# =========================
# OPTIONAL: ANALYTICS & MONITORING
# =========================

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=

# Sentry for error tracking (optional)
# SENTRY_AUTH_TOKEN=

# =========================
# LOGGING & DEBUG
# =========================

# Enable debug logging
# DEBUG=*

# =========================
# SECURITY SETTINGS
# =========================

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate limiting (requests per minute)
# RATE_LIMIT_REQUESTS=100

# =========================
# NOTES
# =========================

# 🔐 SECURITY REMINDERS:
# 1. NEVER commit .env.local to Git - it's in .gitignore
# 2. Use strong, unique JWT_SECRET (at least 32 chars)
# 3. Use strong MongoDB passwords
# 4. In production, use environment variables, not this file
# 5. Rotate secrets regularly
# 6. Use different secrets for dev, staging, and production
# 7. Never share your .env.local file with others

# 📚 HELPFUL RESOURCES:
# - MongoDB Atlas Setup: https://www.mongodb.com/cloud/atlas
# - Generate JWT Secret: openssl rand -base64 32
# - Next.js Env Variables: https://nextjs.org/docs/basic-features/environment-variables
# - Security Best Practices: https://owasp.org/www-project-top-ten/
